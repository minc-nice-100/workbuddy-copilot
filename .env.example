# WorkBuddy Copilot 环境变量配置
# 复制为 .env 后编辑

# LLM API Key（必填）
DEEPSEEK_API_KEY=sk-xxx

# 公网模式：启用后必须设置 student/mentor token，空 token 只允许本地开发
COPILOT_PUBLIC=0

# 认证 Token（公网模式必填）
COPILOT_STUDENT_TOKEN=
COPILOT_MENTOR_TOKEN=

# 服务配置
COPILOT_HOST=0.0.0.0
COPILOT_PORT=8765

# 数据库路径（默认 /var/lib/copilot/data/copilot.db）
COPILOT_DB_PATH=/var/lib/copilot/data/copilot.db